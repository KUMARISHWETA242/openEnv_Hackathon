# ============================================================================
# ENVIRONMENT CONFIGURATION FOR SATELLITE INFERENCE
# ============================================================================
# Copy this to .env and fill in your actual values

# ============================================================================
# PRIMARY CONFIGURATION
# ============================================================================

# Your API key (Hugging Face, OpenAI, etc.)
HF_TOKEN="your_token_here"

# Model to use with the API
MODEL_NAME="openai/gpt-oss-20b:novita"

# API endpoint
API_BASE_URL="https://router.huggingface.co/v1"

# ============================================================================
# RATE LIMITING (prevent credit depletion)
# ============================================================================
# Seconds to wait between API calls
# Increase this to reduce costs! (e.g., 5 or 10 seconds)
REQUEST_DELAY=2.0

# ============================================================================
# FREE ALTERNATIVE OPTIONS
# ============================================================================

# OPTION 1: OLLAMA (Local, FREE, No Limits)
# ─────────────────────────────────────────
# Download: https://ollama.ai
# Setup: ollama pull mistral && ollama serve
# Then use:
#   API_BASE_URL="http://localhost:11434/v1"
#   MODEL_NAME="mistral"
#   HF_TOKEN="ollama"

# OPTION 2: GROQ (Free tier, Very Fast, 25 req/min)
# ────────────────────────────────────────────────
# Get key: https://console.groq.com
# Setup:
#   API_BASE_URL="https://api.groq.com/openai/v1"
#   HF_TOKEN="gsk_your_groq_key"
#   MODEL_NAME="mixtral-8x7b-32768"

# OPTION 3: TOGETHER AI (Free tier available)
# ─────────────────────────────────────────────
# Get key: https://api.together.xyz
# Setup:
#   API_BASE_URL="https://api.together.xyz/v1"
#   HF_TOKEN="your_together_key"
#   MODEL_NAME="meta-llama/Llama-2-7b-chat-hf"

# ============================================================================
# COST-SAVING TIPS
# ============================================================================
# 1. Use Ollama locally (completely free, no rate limits)
# 2. Increase REQUEST_DELAY to 5-10 seconds
# 3. Reduce inference steps (MAX_STEPS in code)
# 4. Use free tier of Groq or Together AI
# ============================================================================
